---
import Layout from '../layouts/Layout.astro';
---

<Layout 
  title="Press Kit | Motunrayo Koyejo" 
  currentPage="press"
>
  <header style="padding: 80px 0 20px;">
    <div class="wrap">
      <div class="eyebrow">Press kit</div>
      <h1>Everything you need to <em>feature me</em>.</h1>
      <p class="lede">Putting together an event program, show notes, or press piece? Grab what you need from here.</p>
    </div>
  </header>

  <section>
    <div class="wrap">
      <h2><em>Headshots</em></h2>
      <p class="section-intro">Studio shots, yours to use for event programs, press, or promo material. Click any image to download the full-resolution file.</p>
      <div class="press-headshots">
        <a class="press-headshot" href="/portrait-pink-arms-crossed.jpg" download>
          <div class="photo ratio-3-4" style="background-image: url('/portrait-pink-arms-crossed.jpg');"></div>
          <div class="dl-label">
            <strong>Full · Portrait</strong>
            <span class="dl-hint">Download ↓</span>
          </div>
        </a>
        <a class="press-headshot" href="/headshot-mint.jpg" download>
          <div class="photo ratio-3-4" style="background-image: url('/headshot-mint.jpg'); background-position: center 20%;"></div>
          <div class="dl-label">
            <strong>Portrait · Green</strong>
            <span class="dl-hint">Download ↓</span>
          </div>
        </a>
        <a class="press-headshot" href="/headshot-mint-seated.jpg" download>
          <div class="photo ratio-3-4" style="background-image: url('/headshot-mint-seated.jpg'); background-position: center 20%;"></div>
          <div class="dl-label">
            <strong>Seated · Green</strong>
            <span class="dl-hint">Download ↓</span>
          </div>
        </a>
        <a class="press-headshot" href="/headshot-cropped.jpg" download>
          <div class="photo ratio-3-4" style="background-image: url('/headshot-cropped.jpg');"></div>
          <div class="dl-label">
            <strong>Tight crop · Headshot</strong>
            <span class="dl-hint">Download ↓</span>
          </div>
        </a>
      </div>
    </div>
  </section>

  <section>
    <div class="wrap">
      <h2>Quick <em>facts</em></h2>
      <div class="press-facts">
        <div class="press-fact">
          <span class="press-fact-label">Name</span>
          <span class="press-fact-value">Motunrayo Koyejo</span>
        </div>
        <div class="press-fact">
          <span class="press-fact-label">Pronunciation</span>
          <span class="press-fact-value">Moh-toon-RAH-yoh Koh-YAY-joh</span>
        </div>
        <div class="press-fact">
          <span class="press-fact-label">Pronouns</span>
          <span class="press-fact-value">she / her</span>
        </div>
        <div class="press-fact">
          <span class="press-fact-label">Current role</span>
          <span class="press-fact-value">Senior Backend Engineer, Cowrywise</span>
        </div>
        <div class="press-fact">
          <span class="press-fact-label">Based in</span>
          <span class="press-fact-value">Lagos, Nigeria</span>
        </div>
        <div class="press-fact">
          <span class="press-fact-label">Speaking topics</span>
          <span class="press-fact-value">Backend, fintech, APIs, women in tech</span>
        </div>
        <div class="press-fact">
          <span class="press-fact-label">Languages</span>
          <span class="press-fact-value">English, Yoruba</span>
        </div>
        <div class="press-fact">
          <span class="press-fact-label">Website</span>
          <span class="press-fact-value">motunrayokoyejo.com</span>
        </div>
      </div>
    </div>
  </section>

  <section>
    <div class="wrap">
      <h2><em>Bios</em>, in three sizes</h2>
      <p class="section-intro">Pick the length that fits your space.</p>

      <!-- Short bio -->
      <div class="bio-block">
        <div class="bio-block-header">
          <span class="bio-block-label">Short · one sentence</span>
          <span class="bio-block-count">~25 words</span>
        </div>
        <p class="bio-block-text" id="bio-short">Motunrayo Koyejo is a software engineer, speaker, and mentor passionate about building reliable financial systems and helping the next generation of women in tech grow their careers.</p>
        <div style="margin-top: 16px;">
          <button class="copy-btn" data-copy-target="bio-short">Copy short bio</button>
        </div>
      </div>

      <!-- Medium bio -->
      <div class="bio-block">
        <div class="bio-block-header">
          <span class="bio-block-label">Medium · two paragraphs</span>
          <span class="bio-block-count">~75 words</span>
        </div>
        <div class="bio-block-text" id="bio-medium">
          <p>Motunrayo Koyejo is a senior software engineer who enjoys solving complex problems in financial technology. Over the past several years, she has worked on the systems behind payments, banking, investments, and other products that people rely on every day.</p>
          <p>Beyond engineering, she is a frequent conference speaker and an active mentor to women entering technology. Through her talks, writing, and mentorship, she helps engineers grow their technical skills, navigate their careers, and build with confidence.</p>
        </div>
        <div style="margin-top: 16px;">
          <button class="copy-btn" data-copy-target="bio-medium">Copy medium bio</button>
        </div>
      </div>

      <!-- Long bio -->
      <div class="bio-block">
        <div class="bio-block-header">
          <span class="bio-block-label">Long · four paragraphs</span>
          <span class="bio-block-count">~150 words</span>
        </div>
        <div class="bio-block-text" id="bio-long">
          <p>Motunrayo Koyejo is a senior software engineer passionate about building reliable technology that solves real problems. Her work has focused on financial systems, from payments and banking infrastructure to investment platforms and the services that keep them running behind the scenes.</p>
          <p>What excites her most is the intersection of technology and impact. She enjoys working on complex engineering challenges, translating technical concepts into practical lessons, and sharing what she's learned through speaking, writing, and mentorship.</p>
          <p>Over the years, she has spoken at conferences and community events across Africa on topics including backend engineering, APIs, fintech, and career growth. She is equally passionate about supporting women entering technology, helping them build confidence, develop technical skills, and navigate the early stages of their careers.</p>
          <p>Whether she's building systems, speaking on stage, or mentoring an aspiring engineer, her goal remains the same: to leave people and technology better than she found them.</p>
        </div>
        <div style="margin-top: 16px;">
          <button class="copy-btn" data-copy-target="bio-long">Copy long bio</button>
        </div>
      </div>
    </div>
  </section>

  <section>
    <div class="wrap">
      <h2>Topics I can <em>talk about</em></h2>
      <p class="section-intro">Areas where I've done the actual work and have opinions worth the stage time.</p>
      <div class="mentor-programs">
        <div class="program">
          <div class="program-name">Backend architecture at scale</div>
          <div class="program-detail">Designing systems that stay fast and reliable as transaction volume grows 10x.</div>
        </div>
        <div class="program">
          <div class="program-name">API design for fintech</div>
          <div class="program-detail">Patterns, pitfalls, and hard-won lessons from building payment and investment APIs.</div>
        </div>
        <div class="program">
          <div class="program-name">Financial inclusion in Africa</div>
          <div class="program-detail">What the infrastructure layer needs to do for fintech to reach the unbanked.</div>
        </div>
        <div class="program">
          <div class="program-name">Women in backend engineering</div>
          <div class="program-detail">Career navigation, visibility, and breaking into deep-tech roles.</div>
        </div>
      </div>
    </div>
  </section>

  <section>
    <div class="wrap">
      <h2>Find me <em>online</em></h2>
      <div class="mentor-programs" style="margin-top: 16px;">
        <div class="program">
          <div class="program-name">LinkedIn</div>
          <div class="program-detail"><a href="https://www.linkedin.com/in/motunrayokoyejo/" target="_blank" rel="noopener" style="color: var(--accent); text-decoration: none;">linkedin.com/in/motunrayokoyejo ↗</a></div>
        </div>
        <div class="program">
          <div class="program-name">X (Twitter)</div>
          <div class="program-detail"><a href="https://x.com/Motushbae" target="_blank" rel="noopener" style="color: var(--accent); text-decoration: none;">@Motushbae ↗</a></div>
        </div>
        <div class="program">
          <div class="program-name">YouTube</div>
          <div class="program-detail"><a href="https://www.youtube.com/@motunrayokoyejo" target="_blank" rel="noopener" style="color: var(--accent); text-decoration: none;">@motunrayokoyejo ↗</a></div>
        </div>
        <div class="program">
          <div class="program-name">TikTok</div>
          <div class="program-detail"><a href="https://www.tiktok.com/@motushbae" target="_blank" rel="noopener" style="color: var(--accent); text-decoration: none;">@motushbae ↗</a></div>
        </div>
        <div class="program">
          <div class="program-name">GitHub</div>
          <div class="program-detail"><a href="https://github.com/motunrayokoyejo" target="_blank" rel="noopener" style="color: var(--accent); text-decoration: none;">github.com/motunrayokoyejo ↗</a></div>
        </div>
        <div class="program">
          <div class="program-name">Email</div>
          <div class="program-detail"><a href="mailto:koyejomotunrayo@gmail.com" style="color: var(--accent); text-decoration: none;">koyejomotunrayo@gmail.com</a></div>
        </div>
      </div>
    </div>
  </section>

  <section>
    <div class="wrap">
      <div class="cta-band">
        <h3>Need something else?</h3>
        <p>If you need something not on this page (a different headshot crop, a tailored bio for a specific angle, or tech specs for a talk), just drop me a line. I'm usually quick.</p>
        <a class="cta-btn" href="mailto:koyejomotunrayo@gmail.com?subject=Press%20inquiry">Contact for press</a>
      </div>
    </div>
  </section>

  <script>
    document.querySelectorAll('.copy-btn').forEach(function(btn) {
      btn.addEventListener('click', function() {
        var targetId = btn.getAttribute('data-copy-target');
        if (targetId) {
          var element = document.getElementById(targetId);
          if (element) {
            var text = (element as HTMLElement).innerText;
            navigator.clipboard.writeText(text).then(function() {
              var originalText = (btn as HTMLElement).innerText;
              (btn as HTMLElement).innerText = '✓ Copied';
              btn.classList.add('copied');
              setTimeout(function() {
                (btn as HTMLElement).innerText = originalText;
                btn.classList.remove('copied');
              }, 2000);
            });
          }
        }
      });
    });
  </script>
</Layout>